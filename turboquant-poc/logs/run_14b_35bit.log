```python
def reverse_linked_list(head):
    prev_node = None
    current_node = head
    
    while current_node is not None:
        next_node = current_node.next  # Store the next node
        current_node.next = prev_node  # Reverse the link
        prev_node = current_node       # Move 'prev' one step forward
        current_node = next_node       # Move 'current' one step forward
    
    return prev_node
```

